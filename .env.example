# ========== Cloudreve 配置 ==========
# 你的 Cloudreve 站点地址（不带末尾斜杠）
SITE_URL=https://demo.cloudreve.org
# Cloudreve 后台设置的"通信密钥"
COMMUNICATION_KEY=your_communication_key_here

# ========== 爱发电配置 ==========
# 爱发电开发者页面获取的 user_id
AFDIAN_USER_ID=your_afdian_user_id
# 爱发电开发者页面底部获取的 API Token
AFDIAN_TOKEN=your_afdian_api_token

# ========== 服务配置 ==========
PORT=5000
LOG_LEVEL=INFO

# ========== 自定义 User-Agent ==========
# 通知 Cloudreve 时使用的 UA
USER_AGENT_CLOUDREVE=AfdPay
# 调用爱发电 API 时使用的 UA
USER_AGENT_AFDIAN=AfdPay

# ========== 可选配置 ==========
# 数据库文件路径（默认 data/afdian_pay.db）
# DB_PATH=data/afdian_pay.db
# 爱发电 API 基础地址（主域名，国内优先）
# AFDIAN_API_BASE=https://ifdian.net
# 爱发电 API 回退地址
# AFDIAN_API_FALLBACK=https://afdian.com
# 爱发电付款页面地址（用户看到的）
# AFDIAN_PAYMENT_BASE=https://ifdian.net
# 最低订单金额（单位：分，默认 500 即 5 元）
# MIN_AMOUNT_FEN=500
# 回调最大重试次数
# NOTIFY_MAX_ATTEMPTS=20
# 回调首次重试延迟（秒）
# NOTIFY_BASE_DELAY=5.0
# 回调最大重试间隔（秒，默认30分钟）
# NOTIFY_MAX_DELAY=1800.0
